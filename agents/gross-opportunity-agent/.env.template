# Gross Opportunity Agent — environment.
# Copy to .env and fill in.  .env is git-ignored.  Load with:  set -a; . ./.env; set +a
#
# ── Which values you must provide, and how to get them ──────────────────────────
#
# SAM_GOV_API_KEY   — you have this. From your sam.gov account (System Account /
#                     Personal API key). Used as the ?api_key= query param on
#                     https://api.sam.gov/prod/opportunities/v2/search
#
# ANTHROPIC_API_KEY — first-party Claude API key from https://console.anthropic.com
#                     (API Keys). Only needed for LOCAL model calls via the direct
#                     'anthropic' transport (Vertex gRPC is blocked by the local proxy).
#                     If you don't have one, leave it blank and set the gate to
#                     deterministic-only locally (the model layer still runs on Cloud Run).
#
# CLOUDSQL_DSN      — already stored in Secret Manager (goa-cloudsql-dsn). Read it with:
#                       gcloud secrets versions access latest --secret=goa-cloudsql-dsn \
#                         --project=isr-division-systems-488723
#                     and paste below, OR leave blank + rely on Secret Manager on Cloud Run.
#
# ── GCP project / stores (already provisioned) ──────────────────────────────────
GOOGLE_CLOUD_PROJECT=isr-division-systems-488723
GOOGLE_CLOUD_LOCATION=us-central1
GOA_BQ_DATASET=goa

# ── Cloud SQL (serving store: tier3 / isrds_db) ─────────────────────────────────
# Paste the DSN from Secret Manager, or leave blank to resolve from the secret at runtime.
CLOUDSQL_DSN=
CLOUDSQL_SSLMODE=require

# ── SAM.gov ─────────────────────────────────────────────────────────────────────
SAM_GOV_API_KEY=

# ── Model engine ────────────────────────────────────────────────────────────────
# Local: 'anthropic' (direct API, works through the proxy). Production/Cloud Run: unset
# (uses engines.json _transport=vertex). engines.json binds all roles to claude-fable-5.
GOA_ENGINE_TRANSPORT=anthropic
ANTHROPIC_API_KEY=

# ── Local resilience flags (unset on Cloud Run) ─────────────────────────────────
# The BigQuery + Firestore gRPC clients are blocked by the local corporate proxy.
# Skip them locally; the serving path (Cloud SQL) is unaffected. UNSET both on Cloud Run.
GOA_SKIP_LAKE=1
GOA_SKIP_ACTIVITY=1

# ── Proxy CA for any HTTPS the app makes locally (SAM.gov, Anthropic) ────────────
SSL_CERT_FILE=/etc/ssl/cert.pem
REQUESTS_CA_BUNDLE=/etc/ssl/cert.pem
