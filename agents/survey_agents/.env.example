# GCP
GOOGLE_CLOUD_PROJECT=isrds-agentic-prod
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_AI_AGENT_ENGINE_ID=         # from Vertex AI console after creating agent resource

# AlloyDB
ALLOYDB_HOST=                      # private IP of AlloyDB primary instance
ALLOYDB_PORT=5432
ALLOYDB_DATABASE=isrds_agentic
ALLOYDB_USER=isrds_agent
ALLOYDB_PASSWORD=                  # or use Secret Manager (recommended)

# Anthropic
ANTHROPIC_API_KEY=                 # store in Secret Manager, reference here for local dev only

# NestJS API (domain connector)
NESTJS_API_BASE_URL=https://api.isrds.com   # or Cloud Run URL
NESTJS_AGENT_API_KEY=                        # shared secret for agent-to-api calls

# Pub/Sub
PUBSUB_ESCALATION_TOPIC=isrds-escalation-v1

# Vertex AI embeddings
VERTEX_EMBEDDING_MODEL=text-embedding-004
