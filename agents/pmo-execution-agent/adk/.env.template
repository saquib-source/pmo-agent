# ╔══════════════════════════════════════════════════════════╗
# ║  PMO Execution Agent — Environment Configuration       ║
# ║                                                        ║
# ║  INSTRUCTIONS:                                         ║
# ║  1. Copy this file:  cp .env.template .env             ║
# ║  2. Fill in your real values below                     ║
# ║  3. NEVER commit the .env file to Git                  ║
# ╚══════════════════════════════════════════════════════════╝

# ── GCP Authentication (for Gemini AI via Vertex AI) ──
# Download your service account JSON from Google Cloud Console:
#   → IAM & Admin → Service Accounts → Keys → Add Key → JSON
# Paths can be RELATIVE (to this adk/ directory) or absolute.
# Example: if your key is in the project root → ../../../your-key.json
GOOGLE_APPLICATION_CREDENTIALS=../../../your-service-account-key.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── SSL Fix (only needed behind corporate proxy/firewall) ──
# If you're NOT behind a corporate firewall, DELETE or comment out these 3 lines.
# Paths can be relative to this adk/ directory.
# SSL_CERT_FILE=./combined-ca-certs.pem
# REQUESTS_CA_BUNDLE=./combined-ca-certs.pem
# GRPC_DEFAULT_SSL_ROOTS_FILE_PATH=./combined-ca-certs.pem

# ── AI Model ──
AGENT_MODEL=gemini-2.5-flash

# ── Jira REST API ──
# Get your API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT=YOUR_PROJECT_KEY

# ── Trust Ledger (audit trail) ──
TRUST_LEDGER_PATH=trust-ledger.jsonl

# ── PMO Daemon Settings (autonomous mode — pmo_daemon.py) ──
PMO_SCAN_INTERVAL_MINUTES=60
PMO_STALE_THRESHOLD_HOURS=24
PMO_CHASE_THRESHOLD_HOURS=48
PMO_ESCALATE_THRESHOLD_HOURS=72
PMO_BRIEF_HOUR=7
PMO_AUTO_COMMENT=false
