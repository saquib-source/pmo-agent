# ── PMO Swarm — Environment Template ──────────────────────────────────────────
# Copy to .env and fill in values. Never commit .env to git.

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://lixillabs.atlassian.net
JIRA_EMAIL=you@isrdsystems.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT=ISRDS

# ── GCP / Vertex AI ───────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=isr-division-systems-488723
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
AGENT_MODEL=gemini-2.5-flash

# ── Layer 1: Config Registry tenant ──────────────────────────────────────────
# Used to scope Firestore config reads (system_config/pmo_agent_config) and observability labels.
TENANT_ID=ashs

# ── Layer 4: Vertex AI Agent Engine (persistent memory) ──────────────────────
# Run: gcloud ai reasoning-engines create --project=isr-division-systems-488723 --region=us-central1
# Then set the numeric engine ID here.  Leave blank to fall back to in-memory sessions.
VERTEX_AGENT_ENGINE_ID=

# ── Layer 8: Observability ────────────────────────────────────────────────────
# Set to false to disable Cloud Logging / Monitoring writes (local dev only).
OBSERVABILITY_ENABLED=true

# ── AlloyDB (PostgreSQL on GCP) — system of record ───────────────────────────
# The isrds_agentic database: config_registry, trust_ledger, agent_memory, daily_briefings
# Get the host from: gcloud alloydb instances describe <instance> --region=us-central1
ALLOYDB_HOST=
ALLOYDB_PORT=5432
ALLOYDB_DATABASE=isrds_agentic
ALLOYDB_USER=
ALLOYDB_PASSWORD=

# ── Trust Ledger — local backup ───────────────────────────────────────────────
# AlloyDB trust_ledger table is the system of record.
# This JSONL file is a local fallback written synchronously on every entry.
TRUST_LEDGER_PATH=trust-ledger.jsonl

# ── Daemon Settings ───────────────────────────────────────────────────────────
PMO_SCAN_INTERVAL_MINUTES=60
PMO_STALE_THRESHOLD_HOURS=24
PMO_CHASE_THRESHOLD_HOURS=48
PMO_ESCALATE_THRESHOLD_HOURS=72
PMO_BRIEF_HOUR=7
PMO_AUTO_COMMENT=false

# ── SSL (local dev only — remove in Cloud Run) ────────────────────────────────
# SSL_CERT_FILE=certs/corporate-ca.pem
# REQUESTS_CA_BUNDLE=certs/corporate-ca.pem
# GRPC_DEFAULT_SSL_ROOTS_FILE_PATH=certs/corporate-ca.pem
