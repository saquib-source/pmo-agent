# REPLACE-agent-id — Environment Configuration
# Copy to .env and fill in real values. NEVER commit secrets to git.

# ── GCP (required for deploy) ──
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Runtime engine (Layer 1 — resolved by Config Registry) ──
# This is the DEFAULT model. In production, config_registry.resolve() overrides this.
AGENT_MODEL=gemini-2.5-flash

# ── MCP Server URLs (Layer 3 — one per tool integration) ──
# Atlassian Jira — use Rovo managed endpoint or your own Cloud Run MCP server
JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp/authv2
JIRA_MCP_TOKEN=your-atlassian-oauth-token

# PostgreSQL — if using a postgres MCP server
# POSTGRES_MCP_URL=http://localhost:5433/mcp

# ── Trust Ledger (Layer 5) ──
# File path for local testing; in production, point to a PostgreSQL table
TRUST_LEDGER_PATH=trust-ledger.jsonl
