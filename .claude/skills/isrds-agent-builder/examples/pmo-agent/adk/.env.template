# pmo-agent — Environment Configuration
# Copy to .env and fill in real values. NEVER commit secrets.

# ── GCP ──
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Runtime engine (Layer 1) ──
AGENT_MODEL=gemini-2.5-flash

# ── Jira MCP (Atlassian Rovo) ──
JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp/authv2
JIRA_MCP_TOKEN=your-atlassian-oauth-token

# ── PostgreSQL MCP (work order database) ──
# POSTGRES_MCP_URL=http://localhost:5433/mcp

# ── Trust Ledger ──
TRUST_LEDGER_PATH=trust-ledger.jsonl
